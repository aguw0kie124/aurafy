# Backend
Frontend__Origin=http://127.0.0.1:5173

# Database
# Paste your Supabase Postgres connection string here.
# Example pooler shape:
# ConnectionStrings__Postgres=Host=aws-0-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.<project-ref>;Password=<database-password>;SSL Mode=Require;Trust Server Certificate=true
ConnectionStrings__Postgres=

# Spotify
Spotify__ClientId=
Spotify__ClientSecret=
Spotify__RedirectUri=http://127.0.0.1:5057/api/auth/spotify/callback

# Frontend
PUBLIC_API_BASE_URL=http://127.0.0.1:5057
